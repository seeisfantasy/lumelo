# Quiet Mode service boundaries.
#
# sessiond may freeze only the explicitly non-critical media work domain.
# Networking, control-plane access, and remote recovery services must stay
# reachable on a headless device.

SESSIOND_PROTECTED_SERVICES="playbackd.service sessiond.service controld.service systemd-networkd.service systemd-resolved.service NetworkManager.service wpa_supplicant.service iwd.service dhcpcd.service ssh.service sshd.service"
SESSIOND_FREEZABLE_SERVICES="media-indexd.service lumelo-media-reconcile.service"
SESSIOND_QUIET_STOP_UNITS="lumelo-wifi-provisiond.service lumelo-bluetooth-provisioning.service bluetooth.service"
SESSIOND_QUIET_START_UNITS="lumelo-bluetooth-provisioning.service lumelo-wifi-provisiond.service bluetooth.service"
SESSIOND_QUIET_MDNS_INTERFACES="auto"
